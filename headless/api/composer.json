{
	"name": "headless/api",
	"type": "phpbb-extension",
	"description": "phpBB 4 Headless REST API — JSON layer for modern frontend applications",
	"version": "1.0.0",
	"license": "GPL-2.0-only",
	"authors": [
		{
			"name": "EBTURK"
		}
	],
	"require": {
		"php": "^8.2",
		"composer/installers": "^1.0 || ^2.0"
	},
	"extra": {
		"display-name": "Headless API",
		"soft-require": {
			"phpbb/phpbb": ">=4.0.0-a2"
		}
	},
	"autoload": {
		"psr-4": {
			"headless\\api\\": ""
		}
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true,
			"phpbb/phpbb": true
		}
	}
}
